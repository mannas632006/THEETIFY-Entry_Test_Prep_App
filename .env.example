# ===========================================================================
# .env.example  --  TEMPLATE FOR YOUR SECRET KEYS
# ===========================================================================
# HOW TO USE THIS FILE (plain English):
#   1. Make a COPY of this file.
#   2. Rename the copy to exactly:  .env   (no ".example" at the end)
#   3. Paste your real keys after the "=" sign for each line below.
#   4. Save the file.
#
# The real ".env" file is IGNORED by Git (see .gitignore), so your secret
# keys will NEVER be uploaded to the internet. This template file is safe
# to upload because it has NO real keys in it.
# ===========================================================================

# --- AI PROVIDER ---------------------------------------------------------
# Which AI service to use. For now we use "groq" (free for testing).
# Later, change this to "claude" when you have a paid Claude key.
AI_PROVIDER=groq

# Your Groq API key (free, for testing). Get one at: https://console.groq.com
# IMPORTANT: paste it ONLY in your private .env file, never anywhere public.
GROQ_API_KEY=

# Your Claude API key (paid, for later). Leave blank until you are ready.
CLAUDE_API_KEY=

# --- SUPABASE (login + database) -----------------------------------------
# Get these from your Supabase project: Settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- PAYMENTS ------------------------------------------------------------
# Stripe (for international users). Test keys are free.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# JazzCash (for Pakistani users). Fill these once you have a merchant account.
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=

# --- YOUTUBE (for fetching video lectures) -------------------------------
# A free Google/YouTube Data API key. Used to auto-find video lectures.
YOUTUBE_API_KEY=
